# ============================================
# DEPENDENCIES
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
package-lock.json

# ============================================
# ENVIRONMENT VARIABLES
# ⚠️ NEVER COMMIT THESE FILES
# ============================================
.env
.env.local
.env.development
.env.test
.env.production
.env.*.local

# Keep only the example file
!.env.example

# ============================================
# LOGS
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# ============================================
# RUNTIME DATA
# ============================================
pids/
*.pid
*.seed
*.pid.lock

# ============================================
# COVERAGE & TESTING
# ============================================
coverage/
*.lcov
.nyc_output/
.grunt/
lib-cov/
.coverage/
.cache/

# ============================================
# BUILD OUTPUT
# ============================================
dist/
build/
out/
.next/
.nuxt/
.vuepress/dist/
.serverless/
.fusebox/
.dynamodb/
.tern-port/

# ============================================
# TEMPORARY FILES
# ============================================
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
# IDE / EDITOR
# ============================================
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-project
*.sublime-workspace
*.iml
.project
.classpath
.c9/
*.lnch
.settings/
*.code-workspace

# ============================================
# OS FILES
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================
# DATABASE
# ============================================
*.sqlite
*.sqlite3
*.db

# ============================================
# CERTIFICATES & KEYS
# ============================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx

# ============================================
# MISC
# ============================================
.cache/
.parcel-cache/
.npm/
.eslintcache
.stylelintcache
.yarn/
.pnp.*

# ============================================
# SERVICE-SPECIFIC
# ============================================
# Each service should have its own .gitignore
# This is the root backend .gitignore

# Shared modules (keep source, ignore builds)
shared/node_modules/
shared/dist/

# Services
services/*/node_modules/
services/*/dist/
services/*/build/
services/*/.env
services/*/.env.local
services/*/.env.*.local
services/*/logs/
services/*/coverage/

# Keep service .env.example files
!services/*/.env.example
